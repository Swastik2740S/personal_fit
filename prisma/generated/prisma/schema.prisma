generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // Clerk user ID (e.g. "user_2abc...")
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())

  // Onboarding profile
  onboardingComplete Boolean @default(false)
  heightCm           Float?
  startingWeightKg   Float?
  age                Int?
  sex                String? // "male" | "female"
  activityLevel      String? // "sedentary" | "lightly" | "moderately" | "very" | "extremely"
  primaryGoal        String? // "fat_loss" | "muscle_gain" | "recomposition" | "maintain"
  fitnessExperience  String? // "beginner" | "intermediate" | "advanced"
  dietaryPreference  String? // "none" | "vegetarian" | "vegan" | "high_protein" | "low_carb"
  equipment          String? // "none" | "home_gym" | "full_gym"

  // Daily goals (auto-set by TDEE on onboarding, overridable in settings)
  calGoal    Int    @default(2350)
  protGoal   Int    @default(160)
  carbGoal   Int    @default(245)
  fatGoal    Int    @default(65)
  stepGoal   Int    @default(8000)
  weightGoal Float?

  // UI appearance preference: "classic" (default frosted) | "liquid" (iOS 26 Liquid Glass)
  uiTheme String @default("classic")

  // Relations
  logs      FoodLog[]
  steps     StepLog[]
  favorites FavoriteFood[]
  weights   WeightLog[]
  plan      UserPlan?
  liftLogs  LiftLog[]
  waters    WaterLog[]
}

// AI-generated personalized plan — one per user, regeneratable
model UserPlan {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealPlan    String // JSON: MealPlanItem[]
  workoutPlan String // JSON: WorkoutDay[]
  summary     String // personalized coaching narrative
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// App-specific models (unchanged)

model FoodCache {
  id        String   @id @default(cuid())
  query     String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodLog {
  id       String   @id @default(cuid())
  userId   String
  name     String
  qty      Float
  cal      Float
  prot     Float
  carb     Float
  fat      Float
  mealType String   @default("Snack")
  date     DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model StepLog {
  id     String   @id @default(cuid())
  userId String
  count  Int
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model FavoriteFood {
  id        String   @id @default(cuid())
  userId    String
  name      String
  cal       Float
  prot      Float
  carb      Float
  fat       Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model WeightLog {
  id     String   @id @default(cuid())
  userId String
  weight Float
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model WaterLog {
  id     String   @id @default(cuid())
  userId String
  ml     Int
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LiftLog {
  id        String   @id @default(cuid())
  userId    String
  exercise  String
  weightKg  Float
  sets      Int
  reps      Int
  notes     String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exercise])
  @@index([userId, date])
}
