// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  logs          FoodLog[]
  steps         StepLog[]
  favorites     FavoriteFood[]

  // Daily goals (defaults mirror the previously hardcoded targets)
  calGoal  Int @default(2350)
  protGoal Int @default(160)
  carbGoal Int @default(245)
  fatGoal  Int @default(65)
  stepGoal Int @default(8000)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Specific Models
model FoodCache {
  id        String   @id @default(cuid())
  query     String   @unique
  data      String   // JSON string of the Edamam results
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FoodLog {
  id        String   @id @default(cuid())
  userId    String
  name      String
  qty       Float
  cal       Float
  prot      Float
  carb      Float
  fat       Float
  mealType  String   @default("Snack") // Breakfast, Lunch, Snack, Dinner
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StepLog {
  id     String   @id @default(cuid())
  userId String
  count  Int
  date   DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// Saved "quick add" foods. Macros are stored per 100g (same basis as search
// results) so a favorite flows straight into the qty modal like any food.
model FavoriteFood {
  id        String   @id @default(cuid())
  userId    String
  name      String
  cal       Float
  prot      Float
  carb      Float
  fat       Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}
